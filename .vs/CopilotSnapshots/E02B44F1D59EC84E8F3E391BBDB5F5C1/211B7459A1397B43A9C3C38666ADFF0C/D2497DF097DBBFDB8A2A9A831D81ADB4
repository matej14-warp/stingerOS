    ds(x+6,tby+6,"Pencil",ds2&&ds2->tool==0?C_ACCENT:C_LGREY,C(30,30,40));
    ds(x+70,tby+6,"Eraser",ds2&&ds2->tool==1?C_ACCENT:C_LGREY,C(30,30,40));
    /* palette */
    uint32_t pal[]={C_WHITE,C_RED,C_GREEN,C_CYAN,C_YELLOW,C_ACCENT,C(255,128,0),C(128,0,255)};
    for(int pi=0;pi<8;pi++){
        int px2=x+140+pi*22;
        dr(px2,tby+4,18,18,pal[pi]);
        if(ds2&&ds2->fg_color==pal[pi])dbdr(px2,tby+4,18,18,C_WHITE);
    }
    /* canvas */
    int cw2=w-2,ch2=h-TITLE_H-28-2;
    int csx=x+1,csy=tby+28;
    int pw=cw2/DRAW_W,ph=ch2/DRAW_H;
    if(pw<1)pw=1;if(ph<1)ph=1;
    if(ds2){
        for(int py=0;py<DRAW_H;py++){
            for(int px2=0;px2<DRAW_W;px2++){
                uint32_t pix=ds2->pixels[py][px2];
                dr(csx+px2*pw,csy+py*ph,pw,ph,pix);
            }
        }
    } else {
        dr(csx,csy,cw2,ch2,C(30,30,40));
    }
    dbdr(csx,csy,cw2,ch2,C_DGREY);
    dbdr(x,y,w,h,foc?C_WBDR_A:C_WBDR_I);
}

